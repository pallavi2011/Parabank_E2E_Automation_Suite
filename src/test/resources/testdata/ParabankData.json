{
  "loginTests": [
    { "scenario": "Positive: Valid Admin", "user": "john", "pass": "demo", "expected": "Success" },
    { "scenario": "Negative: Incorrect Password", "user": "john", "pass": "wrong123", "expected": "Failure" },
    { "scenario": "Negative: Non-existent User", "user": "ghost_user_99", "pass": "pass123", "expected": "Failure" },
    { "scenario": "Boundary: Empty Fields", "user": "", "pass": "", "expected": "Failure" },
    { "scenario": "Edge: SQL Injection Attempt", "user": "' OR '1'='1", "pass": "admin", "expected": "Failure" },
    { "scenario": "Boundary: Max Length Username", "user": "this_is_a_very_long_username_exceeding_fifty_chars_test", "pass": "pass", "expected": "Failure" },
    { "scenario": "Positive: Case Sensitivity Check", "user": "JOHN", "pass": "demo", "expected": "Failure" },
    { "scenario": "Edge: Special Characters", "user": "user!@#$", "pass": "pass%^&*", "expected": "Failure" },
    { "scenario": "Negative: Leading/Trailing Spaces", "user": " john ", "pass": "demo", "expected": "Failure" },
    { "scenario": "Positive: Numeric Username", "user": "12345", "pass": "12345", "expected": "Success" }
  ],

